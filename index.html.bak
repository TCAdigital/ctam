<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Missão CTAM — Organização missionária interdenominacional fundada em 2013. Capacitação online, treinamentos e apoio a missionários para alcançar os Povos Não Alcançados.">
<meta name="keywords" content="missão CTAM, missionários, curso missionário online, povos não alcançados, treinamento missionário, Nova Granada SP">
<meta name="robots" content="index, follow">
<meta property="og:title" content="Missão CTAM — Levando as Boas Novas Onde Poucos Chegam">
<meta property="og:description" content="Organização missionária interdenominacional com obreiros na África, Ásia, América do Sul e Norte do Brasil.">
<meta property="og:type" content="website">
<meta property="og:locale" content="pt_BR">
<link rel="canonical" href="https://www.missaoctam.org/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<title>Missão CTAM — Levando as Boas Novas Onde Poucos Chegam</title>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"Missão CTAM","foundingDate":"2013","address":{"@type":"PostalAddress","addressLocality":"Nova Granada","addressRegion":"SP","addressCountry":"BR"}}</script>
<style>
/* ===== RESET ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Poppins',sans-serif;background:#fff;color:#111827;overflow-x:hidden;line-height:1.6}
img{max-width:100%;display:block}
a{text-decoration:none;color:inherit}
ul{list-style:none}

/* ===== CORES CTAM ===== */
:root{
  --blue:#1A3FA0;
  --blue-dark:#0F2670;
  --red:#E63329;
  --gold:#F5A623;
  --cream:#F9F6F0;
  --beige:#EDE8DE;
  --dark:#111827;
  --gray:#6B7280;
  --white:#fff;
  --font-h:'Bree Serif',serif;
  --font-b:'Poppins',sans-serif;
}

/* ===== HEADER ===== */
#header{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  background:rgba(249,246,240,0.97);
  backdrop-filter:blur(8px);
  border-bottom:1px solid var(--beige);
  transition:box-shadow .3s;
}
#header.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.08)}
.nav-wrap{
  max-width:1280px;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 40px;
}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--font-h);font-size:1.5rem;color:var(--blue)}
.nav-logo .logo-icon{
  width:40px;height:40px;border-radius:50%;
  background:var(--red);display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:1rem;
}
.nav-menu{display:flex;align-items:center;gap:36px}
.nav-menu a{
  font-size:0.82rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--dark);transition:color .2s;position:relative;
}
.nav-menu a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--red);transition:.2s}
.nav-menu a:hover{color:var(--red)}
.nav-menu a:hover::after{width:100%}
.nav-btn{
  background:var(--red);border:2px solid var(--red);color:#fff;
  padding:9px 22px;border-radius:50px;font-size:0.8rem;font-weight:700;
  letter-spacing:1px;text-transform:uppercase;display:flex;align-items:center;gap:8px;
  cursor:pointer;transition:all .25s;
}
.nav-btn:hover{background:#c0251b;border-color:#c0251b;color:#fff}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.hamburger span{display:block;width:26px;height:2px;background:var(--dark);border-radius:2px;transition:.3s}
.nav-mobile{display:none;flex-direction:column;padding:16px 40px 20px;gap:14px;border-top:1px solid var(--beige);background:rgba(249,246,240,0.99)}
.nav-mobile.open{display:flex}
.nav-mobile a{font-size:0.95rem;font-weight:600;color:var(--dark);padding:6px 0;border-bottom:1px solid var(--beige)}

/* ===== HERO ===== */
#hero{
  position:relative;height:100vh;min-height:600px;
  overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;
}
.hero-bg{
  position:absolute;inset:0;
  background:url('https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1600&q=80') center/cover no-repeat;
  animation:kenBurns 20s ease-in-out infinite alternate;
  will-change:transform;
}
@keyframes kenBurns{0%{transform:scale(1) translate(0,0)}100%{transform:scale(1.1) translate(-2%,-1%)}}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.75) 0%,rgba(0,0,0,.3) 50%,rgba(0,0,0,.1) 100%)}
.hero-content{position:relative;z-index:2;padding:0 80px 60px;max-width:900px}
.hero-title{
  font-family:var(--font-h);
  font-size:clamp(2.2rem,5vw,4rem);
  color:#fff;line-height:1.0;text-transform:uppercase;letter-spacing:-1px;
  margin-bottom:28px;text-shadow:0 2px 30px rgba(0,0,0,.3);
}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:48px}
.btn-red{
  background:var(--red);color:#fff;padding:14px 28px;border-radius:4px;
  font-size:0.82rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
  display:inline-flex;align-items:center;gap:10px;border:none;cursor:pointer;transition:all .25s;
}
.btn-red:hover{background:#c0251b;transform:translateY(-2px);box-shadow:0 8px 24px rgba(230,51,41,.35)}
.btn-gold{
  background:var(--gold);color:var(--dark);padding:14px 28px;border-radius:4px;
  font-size:0.82rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
  display:inline-flex;align-items:center;gap:10px;border:none;cursor:pointer;transition:all .25s;
}
.btn-gold:hover{background:#d48f10;transform:translateY(-2px)}
.hero-footnote{position:absolute;bottom:28px;left:80px;color:rgba(255,255,255,.65);font-size:0.82rem;line-height:1.5;z-index:2}
.hero-arrows{position:absolute;bottom:28px;right:40px;z-index:2;display:flex;gap:8px}
.hero-arrow-btn{
  width:44px;height:44px;border-radius:50%;border:1px solid rgba(255,255,255,.4);
  background:rgba(0,0,0,.25);color:#fff;font-size:1rem;
  display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.25s;
}
.hero-arrow-btn:hover{background:rgba(255,255,255,.15)}

/* ===== PARTNERS ===== */
#partners{background:var(--cream);padding:22px 0;border-bottom:1px solid var(--beige);overflow:hidden}
.partners-inner{overflow:hidden;position:relative}
.partners-inner::before,.partners-inner::after{content:'';position:absolute;top:0;bottom:0;width:100px;z-index:2;pointer-events:none}
.partners-inner::before{left:0;background:linear-gradient(to right,var(--cream),transparent)}
.partners-inner::after{right:0;background:linear-gradient(to left,var(--cream),transparent)}
.partners-track{display:flex;align-items:center;gap:70px;width:max-content;animation:slideLeft 30s linear infinite}
.partners-track:hover{animation-play-state:paused}
@keyframes slideLeft{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.p-item{font-family:var(--font-h);font-size:1.1rem;color:var(--blue);opacity:.4;white-space:nowrap;cursor:pointer;transition:.2s}
.p-item:hover{opacity:.9}

/* ===== SOBRE ===== */
#sobre{background:var(--cream);padding:0}
.sobre-wrap{display:grid;grid-template-columns:1fr 1fr;min-height:620px}
.sobre-img{overflow:hidden}
.sobre-img img{width:100%;height:100%;object-fit:cover;display:block}
.sobre-text{padding:80px 70px;background:var(--cream);display:flex;flex-direction:column;justify-content:center}
.tag-red{font-size:0.78rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--red);display:block;margin-bottom:18px}
.sobre-title{font-family:var(--font-h);font-size:clamp(1.8rem,3vw,2.8rem);color:var(--blue-dark);line-height:1.2;margin-bottom:28px}
.sobre-title span{color:var(--red)}
.sobre-desc{font-size:0.9rem;color:var(--gray);line-height:1.8;margin-bottom:20px;max-width:440px}
.sobre-divider{border:none;border-top:1px solid var(--beige);margin:24px 0}
.sobre-bottom{display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start}
.sobre-para{font-size:0.88rem;color:var(--gray);line-height:1.8}
.sobre-stat{text-align:right}
.sobre-stat strong{font-family:var(--font-h);font-size:2.2rem;color:var(--blue-dark);display:block;line-height:1}
.sobre-stat span{font-size:0.78rem;color:var(--gray);line-height:1.4}
.sobre-avatars{display:flex;align-items:center;gap:14px;margin-top:24px}
.av-stack{display:flex}
.av-stack .av{
  width:38px;height:38px;border-radius:50%;border:3px solid var(--cream);
  background:var(--blue);color:#fff;font-size:0.75rem;font-weight:700;
  display:flex;align-items:center;justify-content:center;margin-left:-10px;
}
.av-stack .av:first-child{margin-left:0}
.av-stack .av-gold{background:var(--gold);color:var(--dark)}
.av-info strong{display:block;font-size:0.85rem;color:var(--blue-dark)}
.av-info span{font-size:0.78rem;color:var(--gray)}


.sobre-stat-badge{display:flex;justify-content:flex-end;align-items:flex-start}
.stat-badge-inner{
  background:var(--blue);
  border-radius:12px;padding:24px 28px;text-align:center;
  box-shadow:0 8px 32px rgba(26,63,160,.25);
}
.stat-badge-inner strong{
  font-family:var(--font-h);font-size:2.8rem;color:var(--gold);
  display:block;line-height:1;
}
.stat-badge-inner span{font-size:0.78rem;color:rgba(255,255,255,.85);line-height:1.5;display:block;margin-top:4px}
/* ===== COUNTERS ===== */
#counters{background:var(--blue-dark);padding:60px 40px}
.counters-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr)}
.cnt-item{text-align:center;padding:10px 20px;border-right:1px solid rgba(255,255,255,.12)}
.cnt-item:last-child{border-right:none}
.cnt-num{font-family:var(--font-h);font-size:clamp(3rem,5vw,5rem);color:var(--gold);display:block;line-height:1}
.cnt-label{color:rgba(255,255,255,.7);font-size:0.85rem;margin-top:10px;display:block}

/* ===== ATUAÇÃO (4 Cards com imagem + fade) ===== */
#atuacao{background:var(--cream);padding:90px 40px}
.atuacao-header{text-align:center;margin-bottom:56px}
.tag-center{font-size:0.78rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--red);display:block;margin-bottom:12px}
.atuacao-title{font-family:var(--font-h);font-size:clamp(2rem,3.5vw,3rem);color:var(--blue-dark);line-height:1.2}
.atuacao-title span{color:var(--red)}
.cards-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);overflow:hidden}
.card-c{
  position:relative;overflow:hidden;
  height:420px;cursor:pointer;
}
.card-c-bg{
  position:absolute;inset:0;
  background-size:cover;background-position:center;
  transition:transform .6s ease;
}
.card-c:hover .card-c-bg{transform:scale(1.08)}
/* Overlay gradiente — no repouso cobre mais, no hover revela imagem */
.card-c-overlay{
  position:absolute;inset:0;
  transition:.4s ease;
}
.card-c:nth-child(1) .card-c-overlay{background:linear-gradient(to top, rgba(26,63,160,.92) 0%, rgba(26,63,160,.55) 50%, rgba(26,63,160,.2) 100%)}
.card-c:nth-child(2) .card-c-overlay{background:linear-gradient(to top, rgba(15,38,112,.92) 0%, rgba(15,38,112,.55) 50%, rgba(15,38,112,.2) 100%)}
.card-c:nth-child(3) .card-c-overlay{background:linear-gradient(to top, rgba(230,51,41,.92) 0%, rgba(230,51,41,.55) 50%, rgba(230,51,41,.2) 100%)}
.card-c:nth-child(4) .card-c-overlay{background:linear-gradient(to top, rgba(15,38,112,.95) 0%, rgba(15,38,112,.6) 50%, rgba(26,63,160,.25) 100%)}
.card-c-content{
  position:absolute;bottom:0;left:0;right:0;
  padding:32px 28px;
  transform:translateY(8px);
  transition:transform .4s ease;
}
.card-c:hover .card-c-content{transform:translateY(0)}
.card-c h3{font-family:var(--font-h);font-size:1.25rem;color:#fff;margin-bottom:10px;line-height:1.3}
.card-c p{
  font-size:0.85rem;line-height:1.7;color:rgba(255,255,255,.85);
  max-height:0;overflow:hidden;opacity:0;
  transition:max-height .4s ease, opacity .4s ease;
}
.card-c:hover p{max-height:200px;opacity:1}
.card-c-tag{
  display:inline-block;
  font-size:0.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);margin-bottom:8px;
}

/* ===== CURSO — design da v1 (cards modernos) ===== */
#curso{background:#fff;padding:90px 40px}
.curso-header{text-align:center;max-width:700px;margin:0 auto 56px}
.curso-header p{color:var(--gray);font-size:0.95rem;line-height:1.8;margin-top:14px}
.modulos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;max-width:1100px;margin:0 auto 56px}
.mod-card{border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(26,63,160,.1);transition:.3s}
.mod-card:hover{transform:translateY(-8px);box-shadow:0 16px 48px rgba(26,63,160,.18)}
.mod-head{padding:32px 28px 24px}
.mod-card:nth-child(1) .mod-head{background:var(--blue)}
.mod-card:nth-child(2) .mod-head{background:var(--blue-dark)}
.mod-card:nth-child(3) .mod-head{background:var(--red)}
.mod-num{font-size:0.72rem;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,.6);text-transform:uppercase;display:block;margin-bottom:10px}
.mod-icon{font-size:2rem;margin-bottom:12px;display:block}
.mod-title{font-family:var(--font-h);font-size:1.2rem;color:#fff;line-height:1.3}
.mod-body{background:#fff;padding:24px 28px;border:1px solid var(--beige);border-top:none;border-radius:0 0 12px 12px}
.mod-body ul li{padding:8px 0;border-bottom:1px solid var(--beige);font-size:0.87rem;color:var(--gray);display:flex;align-items:center;gap:10px}
.mod-body ul li:last-child{border-bottom:none}
.mod-body ul li::before{content:'→';color:var(--gold);font-weight:700;flex-shrink:0}
/* CTA Box do curso */
.curso-cta{
  background:linear-gradient(135deg,var(--blue-dark) 0%,var(--blue) 100%);
  border-radius:16px;padding:60px 48px;
  display:flex;align-items:center;justify-content:space-between;gap:40px;
  max-width:1100px;margin:0 auto;position:relative;overflow:hidden;
}
.curso-cta::before{content:'✦';position:absolute;font-size:200px;color:rgba(255,255,255,.03);right:-20px;top:-40px;font-family:serif;line-height:1}
.cta-text h3{font-family:var(--font-h);font-size:2rem;color:#fff;margin-bottom:12px}
.cta-text p{color:rgba(255,255,255,.72);max-width:480px;line-height:1.7;font-size:0.92rem}
.cta-action{flex-shrink:0;text-align:center}
.cta-action .cta-label{font-family:var(--font-h);font-size:1rem;color:rgba(255,255,255,.6);display:block;margin-bottom:16px}


.cta-benefits{list-style:none;margin:20px 0 0;display:flex;flex-direction:column;gap:10px}
.cta-benefits li{display:flex;align-items:center;gap:10px;font-size:.88rem;color:rgba(255,255,255,.82)}
.cta-benefits li i{color:var(--gold);font-size:.9rem;flex-shrink:0}
.cta-seals{display:flex;gap:16px;justify-content:center;margin-bottom:24px}
.seal{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
  border-radius:8px;padding:12px 16px;text-align:center;min-width:76px;
}
.seal i{font-size:1.2rem;color:var(--gold);display:block;margin-bottom:6px}
.seal span{font-size:.72rem;color:rgba(255,255,255,.75);line-height:1.3;display:block}
.btn-cta-big{
  display:flex;align-items:center;justify-content:center;gap:12px;
  background:var(--gold);color:var(--dark);
  padding:18px 36px;border-radius:6px;
  font-size:.95rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  transition:.25s;width:100%;
}
.btn-cta-big:hover{background:#d48f10;transform:translateY(-2px);box-shadow:0 8px 28px rgba(245,166,35,.4)}
.btn-cta-big i{font-size:1.2rem}
.cta-sub{font-size:.75rem;color:rgba(255,255,255,.45);text-align:center;margin-top:12px}
/* ===== DEPOIMENTOS ===== */
#depoimentos{background:var(--cream);padding:90px 40px}
.depo-inner{max-width:900px;margin:0 auto;text-align:center}
.depo-tag{font-size:0.78rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--red);display:block;margin-bottom:12px}
.depo-title{font-family:var(--font-h);font-size:clamp(2rem,3.5vw,3rem);color:var(--blue-dark);margin-bottom:48px}
.depo-stars{color:var(--gold);font-size:1.3rem;letter-spacing:4px;margin-bottom:6px}
.depo-category{font-size:0.82rem;color:var(--gray);margin-bottom:32px;display:block}
.depo-quote{font-family:var(--font-b);font-size:clamp(1rem,2vw,1.25rem);color:var(--blue-dark);line-height:1.8;margin-bottom:36px;font-weight:400;font-style:italic}
.depo-author-wrap{display:flex;align-items:center;justify-content:center;gap:14px}
.depo-av{width:52px;height:52px;border-radius:50%;background:var(--blue);color:#fff;font-weight:700;font-size:0.9rem;display:flex;align-items:center;justify-content:center;border:3px solid var(--beige)}
.depo-author-info strong{display:block;font-size:0.9rem;color:var(--blue-dark)}
.depo-author-info span{font-size:0.78rem;color:var(--gray)}
.depo-slider-wrap{position:relative;padding:0 60px}
/* Setas quadradas exatamente como no print */
.depo-nav{
  position:absolute;top:50%;transform:translateY(-50%);
  width:46px;height:46px;border:1.5px solid var(--beige);
  background:none;border-radius:0;color:var(--blue-dark);font-size:1rem;
  display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;
}
.depo-nav:hover{border-color:var(--red);color:var(--red)}
.depo-nav.prev{left:0}
.depo-nav.next{right:0}
.depo-dots{display:flex;justify-content:center;gap:8px;margin-top:32px}
.depo-dot{width:8px;height:8px;border-radius:50%;background:var(--beige);cursor:pointer;transition:.25s}
.depo-dot.active{background:var(--red);width:28px;border-radius:4px}

/* ===== COMO SE ENVOLVER ===== */
/* Layout exato do print: fundo cream esquerda + foto deslocada | fundo azul escuro direita */
#envolver{background:var(--cream);padding:0}
.envolver-wrap{display:grid;grid-template-columns:1fr 1fr;min-height:580px}
.envolver-left{background:var(--cream);position:relative;display:flex;align-items:flex-end;justify-content:flex-end;padding:60px 0 60px 60px}
.envolver-foto{width:78%;aspect-ratio:3/4;object-fit:cover;display:block;position:relative;z-index:2;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.envolver-right{
  background:var(--blue-dark);padding:80px 70px;
  display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;
}
.envolver-right::before{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.envolver-right>*{position:relative}
.env-tag{font-size:0.75rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:14px}
.env-title{font-family:var(--font-h);font-size:clamp(1.8rem,3vw,2.8rem);color:#fff;line-height:1.2;margin-bottom:16px}
.env-title span{color:var(--gold)}
.env-desc{font-size:0.88rem;color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:36px;max-width:380px}
.env-items{display:flex;flex-direction:column;gap:28px;margin-bottom:40px}
.env-item{display:flex;gap:18px;align-items:flex-start}
.env-num{
  width:52px;height:52px;flex-shrink:0;border-radius:50%;
  background:var(--gold);color:var(--blue-dark);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-h);font-size:1.5rem;font-weight:700;
  box-shadow:0 4px 16px rgba(245,166,35,.35);
}
.env-item h4{font-family:var(--font-h);font-size:1rem;color:#fff;margin-bottom:4px}
.env-item p{font-size:0.83rem;color:rgba(255,255,255,.6);line-height:1.6}

/* ===== AGENDA ===== */
/* Fundo cream, título esquerda, botão vermelho direita, lista eventos bege */
#agenda{background:var(--cream);padding:90px 40px}
.agenda-inner{max-width:1100px;margin:0 auto}
.agenda-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;flex-wrap:wrap;gap:20px}
.agenda-titles .tag-red{margin-bottom:8px}
.agenda-main-title{font-family:var(--font-h);font-size:clamp(2rem,3.5vw,3rem);color:var(--blue-dark);line-height:1.1}
.agenda-main-title span{color:var(--red)}
.eventos{display:flex;flex-direction:column}
.ev-item{
  background:var(--beige);display:flex;align-items:center;gap:28px;
  padding:22px 28px;border-bottom:1px solid #d8d2c8;cursor:pointer;transition:.2s;
}
.ev-item:first-child{border-top:1px solid #d8d2c8}
.ev-item:hover{background:#e0dace;border-left:4px solid var(--red)}
.ev-date{min-width:68px;flex-shrink:0}
.ev-day{font-family:var(--font-h);font-size:2.4rem;color:var(--red);line-height:1;display:block}
.ev-month{font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;display:block}
.ev-img{width:80px;height:80px;border-radius:50%;object-fit:cover;flex-shrink:0;border:3px solid #c8c2b8}
.ev-info{flex:1;min-width:0}
.ev-info h4{font-family:var(--font-h);font-size:1rem;color:var(--blue-dark);margin-bottom:6px}
.ev-meta{display:flex;gap:24px;flex-wrap:wrap}
.ev-meta span{font-size:0.8rem;color:var(--gray);display:flex;align-items:center;gap:6px}
/* Seta circular exatamente como no print */
.ev-arrow{width:44px;height:44px;border-radius:50%;border:1.5px solid var(--red);display:flex;align-items:center;justify-content:center;color:var(--red);font-size:1rem;flex-shrink:0;transition:.2s}
.ev-item:hover .ev-arrow{background:var(--red);color:#fff}

/* ===== GALERIA ===== */
#galeria{background:#fff;padding:80px 0 0}
.galeria-header{text-align:center;padding:0 40px;margin-bottom:48px}
.galeria-header .tag-center{margin-bottom:10px}
.gal-title{font-family:var(--font-h);font-size:clamp(2rem,3.5vw,3rem);color:var(--blue-dark)}
.gal-title span{color:var(--red)}
.gal-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:280px 280px;gap:6px}
.gal-item{overflow:hidden;cursor:pointer;position:relative;background:var(--beige)}
.gal-item:nth-child(1){grid-column:span 2;grid-row:span 2}
.gal-item img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease;display:block}
.gal-item:hover img{transform:scale(1.07)}
.gal-over{position:absolute;inset:0;background:rgba(26,63,160,.45);display:flex;align-items:center;justify-content:center;opacity:0;transition:.3s}
.gal-item:hover .gal-over{opacity:1}
.gal-over span{color:#fff;font-size:1.8rem}
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:9999;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:.3s}
.lightbox.open{opacity:1;pointer-events:all}
.lightbox img{max-width:90vw;max-height:85vh;object-fit:contain;border-radius:8px}
.lb-x{position:absolute;top:20px;right:28px;color:#fff;font-size:2rem;cursor:pointer;background:none;border:none;transition:.2s}
.lb-x:hover{color:var(--red);transform:rotate(90deg)}
.lb-p,.lb-n{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.1);color:#fff;font-size:1.6rem;width:50px;height:50px;border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;border:none}
.lb-p:hover,.lb-n:hover{background:var(--red)}
.lb-p{left:20px}
.lb-n{right:20px}

/* ===== FOOTER ===== */
#footer{background:var(--blue-dark);padding:70px 40px 0;position:relative;overflow:hidden}
#footer::before{content:'';position:absolute;inset:0;pointer-events:none;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}
.footer-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1.6fr;gap:48px;padding-bottom:56px;border-bottom:1px solid rgba(255,255,255,.1);position:relative}
.f-brand{color:rgba(255,255,255,.6)}
.f-logo{display:flex;align-items:center;gap:10px;font-family:var(--font-h);font-size:1.6rem;color:var(--gold);margin-bottom:20px}
.f-logo .f-icon{width:38px;height:38px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.95rem}
.f-brand p{font-size:0.85rem;line-height:1.8;max-width:280px;margin-bottom:24px}
.f-socials{display:flex;gap:10px}
.f-soc{width:38px;height:38px;border-radius:50%;border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.65);font-size:0.9rem;transition:.2s}
.f-soc:hover{background:var(--red);border-color:var(--red);color:#fff}
.f-col h4{font-size:0.78rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#fff;margin-bottom:20px}
.f-col ul li{margin-bottom:12px}
.f-col ul li a{font-size:0.85rem;color:rgba(255,255,255,.55);transition:.2s}
.f-col ul li a:hover{color:var(--gold);padding-left:4px}
/* Card dourado exato do print */
.f-contact-card{background:var(--gold);border-radius:4px;padding:28px 26px;position:relative;overflow:hidden}
.f-contact-card::before{content:'';position:absolute;right:-20px;bottom:-20px;width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,.15)}
.f-contact-card h4{font-family:var(--font-h);font-size:1.05rem;color:var(--blue-dark);margin-bottom:18px;line-height:1.3;position:relative}
.f-contact-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;font-size:0.85rem;color:var(--blue-dark);position:relative}
.f-contact-row:last-child{margin-bottom:0}
.f-contact-row i{margin-top:2px;flex-shrink:0}
.footer-bar{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:18px 0;flex-wrap:wrap;gap:12px;position:relative}
.footer-bar p{font-size:0.78rem;color:rgba(255,255,255,.38)}
.footer-bar .dev{font-size:0.78rem;color:rgba(255,255,255,.5)}
.footer-bar .dev span{color:var(--gold);font-weight:600}
.f-legal{display:flex;gap:16px}
.f-legal a{font-size:0.78rem;color:rgba(255,255,255,.38);transition:.2s}
.f-legal a:hover{color:var(--gold)}

/* ===== WHATSAPP ===== */
.wa-fab{position:fixed;top:50%;right:16px;transform:translateY(-50%);z-index:999;width:58px;height:58px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;box-shadow:0 4px 20px rgba(37,211,102,.5);animation:waPulse 2.5s ease-in-out infinite;transition:transform .2s}
.wa-fab:hover{transform:translateY(-50%) scale(1.1);animation-play-state:paused}
@keyframes waPulse{0%{box-shadow:0 0 0 0 rgba(37,211,102,.6)}60%{box-shadow:0 0 0 18px rgba(37,211,102,0)}100%{box-shadow:0 0 0 0 rgba(37,211,102,0)}}
.back-top{position:fixed;bottom:32px;right:32px;z-index:999;width:42px;height:42px;background:#fff;border:1.5px solid var(--beige);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gray);font-size:1rem;cursor:pointer;opacity:0;pointer-events:none;transition:.3s;box-shadow:0 4px 16px rgba(0,0,0,.1)}
.back-top.show{opacity:1;pointer-events:all}
.back-top:hover{background:var(--blue);color:#fff;border-color:var(--blue)}

/* ===== REVEAL ===== */
.reveal{opacity:0;transform:translateY(36px);transition:opacity .7s ease,transform .7s ease}
.reveal.in{opacity:1;transform:translateY(0)}
.reveal-l{opacity:0;transform:translateX(-36px);transition:opacity .7s ease,transform .7s ease}
.reveal-l.in{opacity:1;transform:translateX(0)}
.reveal-r{opacity:0;transform:translateX(36px);transition:opacity .7s ease,transform .7s ease}
.reveal-r.in{opacity:1;transform:translateX(0)}

/* ===== RESPONSIVE ===== */
@media(max-width:1024px){
  .sobre-wrap,.envolver-wrap{grid-template-columns:1fr}
  .sobre-img{height:420px}
  .envolver-left{padding:60px 40px;justify-content:center}
  .envolver-foto{width:100%;max-width:500px}
  .footer-grid{grid-template-columns:1fr 1fr;gap:36px}
  .cards-grid{grid-template-columns:1fr 1fr}
  .modulos-grid{grid-template-columns:1fr}
  .counters-grid{grid-template-columns:repeat(2,1fr)}
  .cnt-item:nth-child(2){border-right:none}
  .gal-grid{grid-template-columns:repeat(3,1fr);grid-template-rows:240px 240px}
  .gal-item:nth-child(1){grid-column:span 2}
  .curso-cta{flex-direction:column;text-align:center}
  .cta-text p{margin:0 auto}
}
@media(max-width:768px){
  .nav-menu,.nav-btn{display:none}
  .hamburger{display:flex}
  .nav-wrap{padding:14px 20px}
  .hero-content{padding:0 24px 50px}
  .hero-footnote{left:24px}
  .hero-arrows{right:20px}
  #atuacao,#agenda,#curso,#depoimentos,#galeria{padding-left:20px;padding-right:20px}
  #footer{padding:60px 20px 0}
  .footer-grid{grid-template-columns:1fr;gap:28px}
  .footer-bar{flex-direction:column;text-align:center}
  .f-legal{justify-content:center}
  .gal-grid{grid-template-columns:1fr 1fr;grid-template-rows:200px 200px 200px}
  .gal-item:nth-child(1){grid-column:span 2;grid-row:span 1}
  .counters-grid{grid-template-columns:repeat(2,1fr)}
  .cnt-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.1);padding:20px}
  .cnt-item:nth-child(odd){border-right:1px solid rgba(255,255,255,.1)}
  .agenda-head{flex-direction:column;align-items:flex-start}
  .depo-slider-wrap{padding:0 16px}
  .depo-nav{display:none}
  
  .back-top{bottom:20px;right:20px}
  .sobre-text{padding:48px 24px}
  .envolver-right{padding:60px 28px}
  .sobre-bottom{grid-template-columns:1fr}
  .sobre-stat{text-align:left}
  .curso-cta{padding:40px 28px}
}
@media(max-width:480px){
  .hero-title{font-size:2.5rem}
  .cards-grid{grid-template-columns:1fr}
  .ev-img{display:none}
  .gal-grid{grid-template-columns:1fr 1fr;grid-template-rows:160px 160px 160px 160px}
  .gal-item:nth-child(1){grid-column:span 2;grid-row:span 1}
}
</style>
</head>
<body>

<a href="https://wa.me/5517999999999" target="_blank" rel="noopener noreferrer" class="wa-fab" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
<button class="back-top" id="backTop" aria-label="Voltar ao topo"><i class="fas fa-chevron-up"></i></button>

<!-- HEADER -->
<header id="header">
  <div class="nav-wrap">
    <a href="#" class="nav-logo" aria-label="Missão CTAM">
      <div class="logo-icon" aria-hidden="true">→</div>CTAM
    </a>
    <nav class="nav-menu" aria-label="Menu principal">
      <a href="#sobre">Sobre</a>
      <a href="#curso">O Curso</a>
      <a href="#atuacao">Campo</a>
      <a href="#agenda">Agenda</a>
      <a href="#galeria">Galeria</a>
      <a href="#depoimentos">Depoimentos</a>
    </nav>
    <a href="#curso" class="nav-btn">Inscreva-se <i class="fas fa-heart"></i></a>
    <button class="hamburger" id="ham" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
  <nav class="nav-mobile" id="navMob" aria-label="Menu mobile">
    <a href="#sobre">Sobre</a><a href="#curso">O Curso</a><a href="#atuacao">Campo</a>
    <a href="#agenda">Agenda</a><a href="#galeria">Galeria</a><a href="#depoimentos">Depoimentos</a>
    <a href="#curso" style="color:var(--red);font-weight:700">Inscreva-se →</a>
  </nav>
</header>

<!-- HERO -->
<section id="inicio" aria-label="Início">
  <div id="hero">
    <div class="hero-bg" role="img" aria-label="Missão em campo"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-title">Levando as<br>Boas Novas<br>Onde Poucos<br>Chegam.</h1>
      <div class="hero-btns">
        <a href="#curso" class="btn-red">Conheça o Curso <i class="fas fa-arrow-right"></i></a>
        <a href="#sobre" class="btn-gold">Saiba Mais <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
    <div class="hero-footnote">Missão CTAM é uma organização missionária<br>interdenominacional fundada em 2013.</div>
    <div class="hero-arrows" aria-hidden="true">
      <button class="hero-arrow-btn">←</button>
      <button class="hero-arrow-btn">→</button>
    </div>
  </div>
</section>

<!-- PARTNERS -->
<section id="partners" aria-label="Parceiros">
  <div class="partners-inner">
    <div class="partners-track">
      <span class="p-item">Igreja Batista</span><span class="p-item">Presbiteriana</span>
      <span class="p-item">Assembleia de Deus</span><span class="p-item">Igreja Metodista</span>
      <span class="p-item">Congregacional</span><span class="p-item">WEC Internacional</span>
      <span class="p-item">AMTB</span><span class="p-item">Reaching Unreached</span>
      <span class="p-item">Igreja Batista</span><span class="p-item">Presbiteriana</span>
      <span class="p-item">Assembleia de Deus</span><span class="p-item">Igreja Metodista</span>
      <span class="p-item">Congregacional</span><span class="p-item">WEC Internacional</span>
      <span class="p-item">AMTB</span><span class="p-item">Reaching Unreached</span>
    </div>
  </div>
</section>

<!-- SOBRE -->
<section id="sobre" aria-labelledby="sobre-h">
  <div class="sobre-wrap">
    <div class="sobre-img reveal-l">
      <img src="https://images.unsplash.com/photo-1529390079861-591de354faf5?w=900&q=80" alt="Missionários CTAM em campo" loading="lazy" width="700" height="700">
    </div>
    <div class="sobre-text reveal-r">
      <span class="tag-red">Sobre a Missão</span>
      <h2 class="sobre-title" id="sobre-h">Juntos Podemos Alcançar<br>o <span>Mundo Inteiro</span></h2>
      <p class="sobre-desc">A Missão CTAM é uma organização missionária interdenominacional fundada em 2013 pelos pastores Carlos Medeiros e Mara Raquel Medeiros, com base em Nova Granada/SP.</p>
      <hr class="sobre-divider">
      <div class="sobre-bottom">
        <p class="sobre-para">Respeitamos diferentes linhas doutrinárias do contexto evangélico protestante, permitindo que as igrejas locais definam suas próprias estratégias e formas de atuação.</p>
        <div class="sobre-stat-badge">
  <div class="stat-badge-inner">
    <strong>+10</strong>
    <span>Anos de<br>Missão Ativa</span>
  </div>
</div>
      </div>
      <div class="sobre-avatars">
        <div class="av-stack">
          <div class="av">CM</div><div class="av">MR</div><div class="av av-gold">+</div>
        </div>
        <div class="av-info"><strong>Fundadores & Equipe CTAM</strong><span>Comprometidos com o chamado</span></div>
      </div>
      <a href="#curso" class="btn-gold" style="margin-top:32px;align-self:flex-start">Descobrir Mais <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- COUNTERS -->
<section id="counters" aria-label="Números da Missão">
  <div class="counters-grid">
    <div class="cnt-item reveal"><span class="cnt-num" data-target="350">0</span><span class="cnt-label">🎓 Alunos Capacitados</span></div>
    <div class="cnt-item reveal"><span class="cnt-num" data-target="18">0</span><span class="cnt-label">🌍 Nações Alcançadas</span></div>
    <div class="cnt-item reveal"><span class="cnt-num" data-target="2400">0</span><span class="cnt-label">📖 Bíblias Doadas</span></div>
    <div class="cnt-item reveal"><span class="cnt-num" data-target="7000">0</span><span class="cnt-label">🏳️ Povos Não Alcançados</span></div>
  </div>
</section>

<!-- ATUAÇÃO -->
<section id="atuacao" aria-labelledby="atu-h">
  <div class="atuacao-header reveal">
    <span class="tag-center">Como Atuamos</span>
    <h2 class="atuacao-title" id="atu-h">Alcançando os Povos <span>Mais Distantes</span></h2>
  </div>
  <div class="cards-grid reveal">
    <div class="card-c">
      <div class="card-c-bg" style="background-image:url('https://images.unsplash.com/photo-1504052434569-70ad5836ab65?w=600&q=70')"></div>
      <div class="card-c-overlay"></div>
      <div class="card-c-content">
        <span class="card-c-tag">África</span>
        <h3>Campo Africano</h3>
        <p>Obreiros atuando em nações africanas com pouco ou nenhum acesso ao Evangelho, plantando igrejas e discipulando novos crentes.</p>
      </div>
    </div>
    <div class="card-c">
      <div class="card-c-bg" style="background-image:url('https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=600&q=70')"></div>
      <div class="card-c-overlay"></div>
      <div class="card-c-content">
        <span class="card-c-tag">Ásia</span>
        <h3>Campo Asiático</h3>
        <p>Presença estratégica em regiões da Ásia com alta concentração de Povos Não Alcançados e trabalho compassivo.</p>
      </div>
    </div>
    <div class="card-c">
      <div class="card-c-bg" style="background-image:url('https://images.unsplash.com/photo-1516912481808-3406841bd33c?w=600&q=70')"></div>
      <div class="card-c-overlay"></div>
      <div class="card-c-content">
        <span class="card-c-tag">Brasil</span>
        <h3>Norte do Brasil</h3>
        <p>Trabalho entre comunidades ribeirinhas da Amazônia — povos isolados que raramente recebem a visita de missionários.</p>
      </div>
    </div>
    <div class="card-c">
      <div class="card-c-bg" style="background-image:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=70')"></div>
      <div class="card-c-overlay"></div>
      <div class="card-c-content">
        <span class="card-c-tag">América do Sul</span>
        <h3>América do Sul</h3>
        <p>Apoio e mobilização em países da América do Sul, fortalecendo igrejas locais para alcançar populações sem acesso ao Evangelho.</p>
      </div>
    </div>
  </div>
</section>

<!-- CURSO -->
<section id="curso" aria-labelledby="curso-h">
  <div style="max-width:1100px;margin:0 auto">
    <div class="curso-header reveal">
      <span class="tag-center">Capacitação Online</span>
      <h2 class="atuacao-title" id="curso-h">Grade <span style="color:var(--red)">Curricular</span></h2>
      <p>Um curso em 3 módulos e 12 matérias — a porta de entrada para amadurecer seu chamado missionário. 100% online, para todo o Brasil e o mundo.</p>
    </div>
    <div class="modulos-grid">
      <article class="mod-card reveal">
        <div class="mod-head"><span class="mod-num">Módulo 01</span><span class="mod-icon">🌱</span><h3 class="mod-title">Uma Jornada à Maturidade</h3></div>
        <div class="mod-body"><ul>
          <li>Aula Inaugural</li><li>Alma Curada, Obreiro Aperfeiçoado</li>
          <li>Disciplinas Espirituais</li><li>Dons e Ministérios</li>
        </ul></div>
      </article>
      <article class="mod-card reveal" style="transition-delay:.15s">
        <div class="mod-head"><span class="mod-num">Módulo 02</span><span class="mod-icon">📖</span><h3 class="mod-title">Uma Jornada pela Teologia</h3></div>
        <div class="mod-body"><ul>
          <li>Missões e a Adoração</li><li>Hermenêutica Missiológica</li>
          <li>Panorama Bíblico</li><li>Missio Dei — Enviados e Sustentados por Deus</li>
          <li>Rumos da Missão — Atos dos Apóstolos</li>
        </ul></div>
      </article>
      <article class="mod-card reveal" style="transition-delay:.3s">
        <div class="mod-head"><span class="mod-num">Módulo 03</span><span class="mod-icon">🌐</span><h3 class="mod-title">Uma Jornada aos Campos</h3></div>
        <div class="mod-body"><ul>
          <li>Visão Global</li><li>Mobilização Missionária</li>
          <li>Planejamento Missionário — Do Lar ao Campo</li><li>Evangelismo e Discipulado</li>
        </ul></div>
      </article>
    </div>
    <div class="curso-cta reveal" id="contato">
      <div class="cta-text">
        <span style="font-size:.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:14px">Dê o próximo passo</span>
        <h3>Pronto para responder<br>ao chamado?</h3>
        <ul class="cta-benefits">
          <li><i class="fas fa-check-circle"></i> 3 módulos e 12 matérias online</li>
          <li><i class="fas fa-check-circle"></i> Apoio pastoral e cuidado integral</li>
          <li><i class="fas fa-check-circle"></i> Interdenominacional — sua doutrina, respeitada</li>
          <li><i class="fas fa-check-circle"></i> Certificado ao final do curso</li>
        </ul>
      </div>
      <div class="cta-action">
        <div class="cta-seals">
          <div class="seal"><i class="fas fa-globe"></i><span>Desde<br>2013</span></div>
          <div class="seal"><i class="fas fa-users"></i><span>+350<br>Alunos</span></div>
          <div class="seal"><i class="fas fa-star"></i><span>100%<br>Online</span></div>
        </div>
        <a href="https://wa.me/5517999999999" target="_blank" rel="noopener" class="btn-cta-big">
          <i class="fab fa-whatsapp"></i> Quero me Inscrever
        </a>
        <p class="cta-sub">Fale conosco pelo WhatsApp e tire todas as dúvidas</p>
      </div>
    </div>
  </div>
</section>

<!-- DEPOIMENTOS -->
<section id="depoimentos" aria-labelledby="depo-h">
  <div class="depo-inner">
    <span class="depo-tag">Depoimentos</span>
    <h2 class="depo-title" id="depo-h">O que Dizem Nossos <span style="color:var(--red)">Alunos</span></h2>
    <div class="depo-slider-wrap">
      <button class="depo-nav prev" id="dPrev" aria-label="Anterior">←</button>
      <div id="depoContent" role="region" aria-live="polite"></div>
      <button class="depo-nav next" id="dNext" aria-label="Próximo">→</button>
    </div>
    <div class="depo-dots" id="dDots" role="tablist"></div>
  </div>
</section>

<!-- COMO SE ENVOLVER -->
<section id="envolver" aria-labelledby="env-h">
  <div class="envolver-wrap">
    <div class="envolver-left reveal-l">
      <img class="envolver-foto" src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=700&q=80" alt="Missão em campo" loading="lazy" width="500" height="650">
    </div>
    <div class="envolver-right reveal-r">
      <span class="env-tag">Faça Parte</span>
      <h2 class="env-title" id="env-h">Como Você Pode<br><span>Se Envolver</span></h2>
      <p class="env-desc">Há um papel para cada pessoa nessa missão. Seja chamado ao campo, à oração ou ao suporte — a CTAM tem um caminho para você.</p>
      <div class="env-items">
        <div class="env-item"><div class="env-num">1</div><div><h4>Faça o Curso Online</h4><p>3 módulos e 12 matérias para preparar missionários responsáveis e maduros espiritualmente.</p></div></div>
        <div class="env-item"><div class="env-num">2</div><div><h4>Parceria com sua Igreja</h4><p>Sua comunidade pode ser parceira da CTAM, enviando missionários e participando dos eventos.</p></div></div>
        <div class="env-item"><div class="env-num">3</div><div><h4>Apoio em Oração e Financeiro</h4><p>Sustente obreiros em campo. Cada contribuição leva o Evangelho mais longe.</p></div></div>
      </div>
      <a href="https://wa.me/5517999999999" target="_blank" rel="noopener" class="btn-gold" style="align-self:flex-start">Descobrir Mais <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- AGENDA -->
<section id="agenda" aria-labelledby="ag-h">
  <div class="agenda-inner">
    <div class="agenda-head">
      <div class="agenda-titles reveal">
        <span class="tag-red">Próximos Eventos</span>
        <h2 class="agenda-main-title" id="ag-h">Nossa <span>Agenda.</span></h2>
      </div>
      <a href="#" class="btn-red reveal">Todos os Eventos <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="eventos reveal" id="eventosList"></div>
  </div>
</section>

<!-- GALERIA -->
<section id="galeria" aria-labelledby="gal-h">
  <div class="galeria-header reveal">
    <span class="tag-center">Memórias do Campo</span>
    <h2 class="gal-title" id="gal-h">Nossa <span>Galeria</span></h2>
  </div>
  <div class="gal-grid" id="galGrid" role="list"></div>
</section>

<div class="lightbox" id="lb" role="dialog" aria-modal="true">
  <button class="lb-x" id="lbX" aria-label="Fechar">✕</button>
  <button class="lb-p" id="lbP" aria-label="Anterior">‹</button>
  <img id="lbImg" src="" alt="">
  <button class="lb-n" id="lbN" aria-label="Próxima">›</button>
</div>

<!-- FOOTER -->
<footer id="footer" role="contentinfo">
  <div class="footer-grid">
    <div class="f-brand">
      <div class="f-logo"><div class="f-icon">→</div> CTAM</div>
      <p>Levando as boas novas onde poucos chegam. Com base em Nova Granada/SP, a Missão CTAM mobiliza e capacita igrejas para alcançar os Povos Não Alcançados desde 2013.</p>
      <div class="f-socials">
        <a href="#" class="f-soc" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="f-soc" aria-label="X/Twitter"><i class="fab fa-x-twitter"></i></a>
        <a href="#" class="f-soc" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://wa.me/5517999999999" class="f-soc" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
      </div>
    </div>
    <div class="f-col">
      <h4>Explorar</h4>
      <ul>
        <li><a href="#sobre">Sobre a Missão</a></li>
        <li><a href="#curso">O Curso Online</a></li>
        <li><a href="#atuacao">Onde Atuamos</a></li>
        <li><a href="#agenda">Agenda</a></li>
        <li><a href="#galeria">Galeria</a></li>
      </ul>
    </div>
    <div class="f-col">
      <h4>Se Envolver</h4>
      <ul>
        <li><a href="#curso">Fazer o Curso</a></li>
        <li><a href="#envolver">Parceria Igreja</a></li>
        <li><a href="#envolver">Apoio Financeiro</a></li>
        <li><a href="#depoimentos">Depoimentos</a></li>
        <li><a href="#contato">Fale Conosco</a></li>
      </ul>
    </div>
    <div class="f-col">
      <h4>Contato</h4>
      <div class="f-contact-card">
        <h4>Nova Granada/SP<br>A 30 min de S.J. Rio Preto</h4>
        <div class="f-contact-row"><i class="fab fa-whatsapp"></i> (17) 9 9999-9999</div>
        <div class="f-contact-row"><i class="fas fa-envelope"></i> contato@missaoctam.org</div>
      </div>
    </div>
  </div>
  <div class="footer-bar">
    <p>© 2025 Missão CTAM. Todos os direitos reservados.</p>
    <p class="dev">Desenvolvido com amor ❤️ pela <a href="https://www.tcadigital.com.br/express" target="_blank" rel="noopener" style="color:var(--gold);font-weight:600;text-decoration:none;transition:.2s">TCA Digital Ai-Driven</a></p>
    <div class="f-legal"><a href="#">Termos de Uso</a><a href="#">Privacidade</a></div>
  </div>
</footer>

<script>
const depos=[
  {stars:5,cat:"Aluna do Curso Online",quote:'"O curso da Missão CTAM transformou minha visão sobre o chamado missionário. As matérias são profundas e moldaram meu coração para os povos não alcançados."',name:"Ana Carolina Silva",role:"Missionária, Goiânia/GO",init:"AC"},
  {stars:5,cat:"Participante do Acampamento",quote:'"Fui ao acampamento sem saber o que esperar e voltei com certeza do meu chamado. A equipe da CTAM cuida com amor de cada vocacionado."',name:"Marcos Oliveira",role:"Pastor, São Paulo/SP",init:"MO"},
  {stars:5,cat:"Aluno do Curso Online",quote:'"A grade curricular é completa e equilibrada — teologia, espiritualidade e prática de campo. Recomendo para quem sente o chamado missionário."',name:"João Pedro Ferreira",role:"Obreiro, Recife/PE",init:"JP"},
  {stars:5,cat:"Parceiro Institucional",quote:'"Nossa igreja firmou parceria com a CTAM e vimos o chamado missionário despertar em vários membros. A mobilização deles é séria e com muito fruto."',name:"Rev. Samuel Costa",role:"Pastor, Manaus/AM",init:"SC"}
];
const eventos=[
  {day:"14",month:"Jun, 2025",title:"Acampamento Missionário de Inverno",time:"08h00 – 18h00",local:"Base CTAM – Nova Granada/SP",img:"https://images.unsplash.com/photo-1504052434569-70ad5836ab65?w=160&q=70"},
  {day:"28",month:"Jun, 2025",title:"Oficina de Evangelismo e Discipulado",time:"09h00 – 17h00",local:"Online – Transmissão ao Vivo",img:"https://images.unsplash.com/photo-1529390079861-591de354faf5?w=160&q=70"},
  {day:"19",month:"Jul, 2025",title:"Treinamento de Curto Prazo no Campo",time:"Duração: 2 semanas",local:"Norte do Brasil – Comunidades Ribeirinhas",img:"https://images.unsplash.com/photo-1516912481808-3406841bd33c?w=160&q=70"},
  {day:"09",month:"Ago, 2025",title:"Conferência Missões e Adoração",time:"19h00 – 22h00",local:"Nova Granada/SP + Transmissão Online",img:"https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=160&q=70"}
];
const fotos=[
  {src:"https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=900&q=75",alt:"Missionários em campo"},
  {src:"https://images.unsplash.com/photo-1504052434569-70ad5836ab65?w=600&q=75",alt:"Trabalho missionário"},
  {src:"https://images.unsplash.com/photo-1529390079861-591de354faf5?w=600&q=75",alt:"Treinamento CTAM"},
  {src:"https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&q=75",alt:"Família missionária"},
  {src:"https://images.unsplash.com/photo-1516912481808-3406841bd33c?w=900&q=75",alt:"Campo na Amazônia"},
  {src:"https://images.unsplash.com/photo-1478737270239-2f02b77fc618?w=500&q=75",alt:"Culto e adoração"},
  {src:"https://images.unsplash.com/photo-1487213802982-74d73802997c?w=500&q=75",alt:"Comunidade alcançada"},
];

// Depoimentos
let dIdx=0;
function renderDepo(){
  const d=depos[dIdx];
  document.getElementById('depoContent').innerHTML=`
    <div class="depo-stars">${'★'.repeat(d.stars)}</div>
    <span class="depo-category">${d.cat}</span>
    <p class="depo-quote">${d.quote}</p>
    <div class="depo-author-wrap">
      <div class="depo-av">${d.init}</div>
      <div class="depo-author-info"><strong>${d.name}</strong><span>${d.role}</span></div>
    </div>`;
  const dots=document.getElementById('dDots');
  dots.innerHTML=depos.map((_,i)=>`<div class="depo-dot${i===dIdx?' active':''}" data-i="${i}" role="tab"></div>`).join('');
  dots.querySelectorAll('.depo-dot').forEach(d=>d.addEventListener('click',()=>{dIdx=+d.dataset.i;renderDepo();}));
}
renderDepo();
document.getElementById('dPrev').onclick=()=>{dIdx=(dIdx-1+depos.length)%depos.length;renderDepo()};
document.getElementById('dNext').onclick=()=>{dIdx=(dIdx+1)%depos.length;renderDepo()};
setInterval(()=>{dIdx=(dIdx+1)%depos.length;renderDepo();},6000);

// Eventos
document.getElementById('eventosList').innerHTML=eventos.map(e=>`
  <article class="ev-item" tabindex="0">
    <div class="ev-date"><span class="ev-day">${e.day}</span><span class="ev-month">${e.month}</span></div>
    <img class="ev-img" src="${e.img}" alt="${e.title}" loading="lazy" width="80" height="80">
    <div class="ev-info"><h4>${e.title}</h4>
      <div class="ev-meta">
        <span><i class="far fa-clock"></i> ${e.time}</span>
        <span><i class="fas fa-map-marker-alt"></i> ${e.local}</span>
      </div>
    </div>
    <div class="ev-arrow" aria-hidden="true">→</div>
  </article>`).join('');

// Galeria
const grid=document.getElementById('galGrid');
fotos.forEach((f,i)=>{
  const d=document.createElement('div');
  d.className='gal-item';d.setAttribute('role','listitem');
  d.innerHTML=`<img src="${f.src}" alt="${f.alt}" loading="lazy" width="400" height="300"><div class="gal-over"><span>🔍</span></div>`;
  d.addEventListener('click',()=>openLb(i));
  grid.appendChild(d);
});

// Lightbox
let lbI=0;
const lb=document.getElementById('lb'),lbImg=document.getElementById('lbImg');
function openLb(i){lbI=i;lbImg.src=fotos[i].src;lbImg.alt=fotos[i].alt;lb.classList.add('open');document.body.style.overflow='hidden';}
function closeLb(){lb.classList.remove('open');document.body.style.overflow='';}
document.getElementById('lbX').onclick=closeLb;
document.getElementById('lbP').onclick=()=>{lbI=(lbI-1+fotos.length)%fotos.length;lbImg.src=fotos[lbI].src;};
document.getElementById('lbN').onclick=()=>{lbI=(lbI+1)%fotos.length;lbImg.src=fotos[lbI].src;};
lb.addEventListener('click',e=>{if(e.target===lb)closeLb();});
document.addEventListener('keydown',e=>{if(!lb.classList.contains('open'))return;if(e.key==='Escape')closeLb();if(e.key==='ArrowLeft')document.getElementById('lbP').click();if(e.key==='ArrowRight')document.getElementById('lbN').click();});

// Header
const hdr=document.getElementById('header');
window.addEventListener('scroll',()=>{
  hdr.classList.toggle('scrolled',scrollY>60);
  document.getElementById('backTop').classList.toggle('show',scrollY>400);
},{passive:true});
document.getElementById('backTop').onclick=()=>window.scrollTo({top:0,behavior:'smooth'});

// Hamburger
const ham=document.getElementById('ham'),mob=document.getElementById('navMob');
ham.onclick=()=>{const o=mob.classList.toggle('open');ham.setAttribute('aria-expanded',o);};
mob.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>mob.classList.remove('open')));

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>a.addEventListener('click',e=>{
  const t=document.querySelector(a.getAttribute('href'));
  if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth'});}
}));

// Reveal
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target);}}),{threshold:0.1});
document.querySelectorAll('.reveal,.reveal-l,.reveal-r').forEach(el=>obs.observe(el));

// Counters
const cobs=new IntersectionObserver(entries=>entries.forEach(e=>{
  if(e.isIntersecting){
    const el=e.target,tgt=+el.dataset.target;let cur=0;const step=tgt/80;
    const t=setInterval(()=>{cur+=step;if(cur>=tgt){cur=tgt;clearInterval(t);}el.textContent='+'+Math.floor(cur).toLocaleString('pt-BR');},20);
    cobs.unobserve(el);
  }
}),{threshold:0.5});
document.querySelectorAll('.cnt-num').forEach(el=>cobs.observe(el));
</script>
</body>
</html>
